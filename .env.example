# =============================================================================
# TTA — Environment Variables
# =============================================================================
# Canonical template committed to git.
#
# Local workflow options:
#   1. Plain local values:
#      cp .env.example .env
#      # edit .env with real values
#
#   2. 1Password-backed generation:
#      cp .env.example .env
#      # replace selected values with op:// references
#      op inject -i .env -o .env.resolved
#      mv .env.resolved .env
#
# After .env exists, the app loads it directly. Do not wrap every command in
# `op run --env-file=...`. `.env` is gitignored and should never be committed.

# --- LLM backend ---
# openai (default) = any OpenAI-compatible endpoint, including free-model-router.
# openrouter = OpenRouter direct.
# anthropic = Claude direct.
TTA_LLM_BACKEND=openai
TTA_OPENAI_API_BASE=http://localhost:3456/v1
TTA_OPENAI_API_KEY=free-model-router

# Optional global model override (otherwise per-role defaults apply)
TTA_LITELLM_MODEL=openai/gpt-4o-mini
TTA_LITELLM_FALLBACK_MODEL=openai/gpt-4o-mini

# --- PostgreSQL (required) ---
TTA_DATABASE_URL=postgresql+asyncpg://tta:tta@localhost:5433/tta

# --- Neo4j (required password, URI optional if graph features disabled) ---
TTA_NEO4J_URI=bolt://localhost:7688
TTA_NEO4J_USER=neo4j
TTA_NEO4J_PASSWORD=CHANGE_ME_BEFORE_RUNNING

# --- Redis ---
TTA_REDIS_URL=redis://localhost:6380

# --- Langfuse (optional — leave blank to disable) ---
TTA_LANGFUSE_HOST=
TTA_LANGFUSE_PUBLIC_KEY=
TTA_LANGFUSE_SECRET_KEY=

# --- Application ---
TTA_ENVIRONMENT=development
TTA_LOG_LEVEL=INFO
TTA_LOG_FORMAT=json
TTA_IDLE_TIMEOUT_MINUTES=30
TTA_SESSION_TOKEN_TTL=86400
TTA_JWT_SECRET=CHANGE-ME-IN-PRODUCTION-minimum-32-bytes

# --- Monitoring (Grafana) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_BEFORE_RUNNING
