# =============================================================================
# TTA — Environment Variables
# =============================================================================
# Copy to .env and fill in required values.
# See specs/system.md §7.4 for documentation.

# --- PostgreSQL (required) ---
TTA_DATABASE_URL=postgresql+asyncpg://tta:tta@localhost:5432/tta

# --- Neo4j ---
TTA_NEO4J_URI=bolt://localhost:7687
TTA_NEO4J_USER=neo4j
TTA_NEO4J_PASSWORD=changeme

# --- Redis ---
TTA_REDIS_URL=redis://localhost:6379

# --- LLM (LiteLLM) ---
TTA_LITELLM_MODEL=openai/gpt-4o-mini
TTA_LITELLM_FALLBACK_MODEL=openai/gpt-4o-mini

# --- Langfuse (optional — leave blank to disable) ---
TTA_LANGFUSE_HOST=
TTA_LANGFUSE_PUBLIC_KEY=
TTA_LANGFUSE_SECRET_KEY=

# --- Application ---
TTA_ENVIRONMENT=development
TTA_LOG_LEVEL=INFO
TTA_LOG_FORMAT=json
TTA_SESSION_TOKEN_TTL=86400
