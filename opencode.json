{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "hindsight": {
      "type": "remote",
      "url": "http://localhost:8888/mcp/"
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "serena": {
      "type": "local",
      "command": [
        "/usr/bin/uvx",
        "--from", "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context", "claude-code"
      ],
      "enabled": true
    },
    "cgc": {
      "type": "local",
      "command": ["cgc", "mcp", "start"],
      "enabled": true
    }
  }
}